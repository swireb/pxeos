#!/bin/bash
. /usr/share/pxeos/lib/funcs.sh
### If USB Boot device we need a way to get the kernel args properly
if [[ $boottype == usb && ! -z $web ]]; then
    sysuuid=$(dmidecode -s system-uuid)
    sysuuid=${sysuuid,,}
    usb_macs=$(getMACAddresses)
    base64mac=$(echo $usb_macs | base64)
    token=$(curl -Lks --data "mac=$base64mac" "${web}status/hostgetkey.php")
    curl -Lks -o /tmp/hinfo.txt --data "sysuuid=${sysuuid}&mac=$usb_macs&hosttoken=${token}" "${web}service/hostinfo.php" -A ''
    [[ -f /tmp/hinfo.txt ]] && . /tmp/hinfo.txt
fi
dots "Running post init scripts"
[[ ! -d /imagesinit ]] && mkdir /imagesinit >/dev/null 2>&1
umount /imagesinit >/dev/null 2>&1
mount -o nolock,proto=tcp,rsize=32768,wsize=32768,intr,noatime "$storage" /imagesinit >/tmp/mount-output 2>&1
if [[ $? -eq 0 ]]; then
    if [[ -f /imagesinit/.mntcheck ]]; then
        export_abs="${export_path:-${exportpath:-/images}}"
        postinit_abs="${postinit_path:-${postinitpath:-}}"
        [[ -z $postinit_abs ]] && postinit_abs="${export_abs%/}/postinitscripts"
        postinit_local="$(rootpxe_map_nfs_abs_to_local "/imagesinit" "$export_abs" "$postinit_abs")"
        if [[ -f "$postinit_local/pxeos.postinit" ]]; then
            . "$postinit_local/pxeos.postinit"
        fi
    fi
    umount /imagesinit >/dev/null 2>&1
    echo "Done"
    debugPause
else
    echo "Skipped"
    debugPause
fi
if [[ -n $mode && $mode != +(*debug*) && -z $type ]]; then
    case $mode in
        wipe)
            pxeos.wipe
            ;;
        checkdisk)
            pxeos.testdisk
            ;;
        photorec)
            pxeos.photorec
            ;;
        badblocks)
            pxeos.surfacetest
            ;;
        clamav)
            pxeos.av
            ;;
        autoreg)
            pxeos.auto.reg
            ;;
        manreg)
            pxeos.man.reg
            ;;
        inventory)
            pxeos.inventory
            ;;
        capone)
            pxeos.capone
            ;;
        winpassreset)
            pxeos.chntpw
            ;;
        quickimage)
            pxeos.quickimage
            ;;
        sysinfo)
            pxeos.sysinfo
            ;;
        *)
            handleError "Fatal Error: Unknown mode :: $mode ($0)\n   Args Passed: $*"
            ;;
    esac
else
    case $type in
        down)
            pxeos.download
            ;;
        up)
            pxeos.upload
            ;;
        *)
            [[ -z $type ]] && type="Null"
            handleError "Fatal Error: Unknown request type :: $type"
            ;;
    esac
fi
